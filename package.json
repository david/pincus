{
  "name": "pi-bash-incus",
  "version": "0.1.1",
  "description": "Run Pi bash commands inside an Incus container",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/david/pi-bash-incus.git"
  },
  "keywords": [
    "pi-package",
    "pi-extension",
    "incus",
    "container"
  ],
  "files": [
    "extensions",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "check": "tsc --noEmit",
    "test": "node --experimental-strip-types tests/bash-incus.test.ts"
  },
  "pi": {
    "extensions": [
      "./extensions/bash-incus.ts"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "0.80.7",
    "@types/node": "^24.13.3",
    "typebox": "^1.3.6",
    "typescript": "^7.0.2"
  },
  "engines": {
    "node": ">=22.6"
  }
}
