{
  "name": "pincus",
  "version": "0.3.0",
  "description": "Route Pi's built-in project tools into existing Incus containers",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/david/pincus.git"
  },
  "keywords": [
    "pi-package",
    "pi-extension",
    "incus",
    "container"
  ],
  "files": [
    "extensions",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "check": "tsc --noEmit",
    "test": "node --experimental-strip-types --test tests/*.test.ts",
    "test:smoke": "PINCUS_INCUS_SMOKE=1 node --experimental-strip-types --test tests/incus-smoke.test.ts"
  },
  "pi": {
    "extensions": [
      "./extensions/pincus.ts"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "0.80.7",
    "@types/node": "^24.13.3",
    "typebox": "^1.3.6",
    "typescript": "^7.0.2"
  },
  "engines": {
    "node": ">=22.6"
  }
}
